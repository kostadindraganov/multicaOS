# tank configuration — example values.
#
# Two kinds of setting:
#   1. Bootstrap (env-only): read at process start. Set these in the systemd
#      unit / deploy environment. Changing them needs a restart.
#   2. Runtime: seeded into the SQLite `config` table on first boot from the
#      matching TANK_<KEY> var below, then editable live from the dashboard
#      settings cog. After first boot the DB value wins, so editing this file
#      only affects a fresh database.
#
# Nothing here is secret. Claude auth lives in ~/.claude/.credentials.json on
# the host (set via the dashboard login flow), never in this repo.
#
# Host-local overrides: copy the runtime lines you want into a gitignored
# `tank.local.env` next to deploy.sh (or at <install-dir>/tank.local.env on the
# host). The systemd unit loads it via `EnvironmentFile=-`, and deploy.sh ships
# it if present. This is how you seed private values (e.g. an internal model
# endpoint) into a fresh DB without committing them. After first boot the DB
# value wins, so the file is redundant and can be deleted.

# ── Bootstrap (env-only) ──────────────────────────────────────────────────────
# Where the app is deployed and what port it binds.
TANK_INSTALL_DIR=/opt/tank
TANK_PORT=7878
# The unprivileged user the service runs as. Claude refuses
# --dangerously-skip-permissions as root, so this must NOT be root.
TANK_SERVICE_USER=tank

# ── Deploy-only (consumed by deploy.sh, not the app) ──────────────────────────
# SSH target deploy.sh pushes to, e.g. root@192.0.2.10 or an ssh config alias.
TANK_DEPLOY_HOST=root@your-host
# Home directory of the service user on the target.
TANK_SERVICE_HOME=/home/tank
# Optional, dual-purpose. (1) deploy.sh refreshes the vendored house-style
# design assets (static/house-style/) from this URL at deploy time. (2) It also
# seeds the runtime `house_style_url` setting, so the served HTML links the
# design system from here (each asset falling back to the vendored copy if the
# host is unreachable) — set it to track a live channel, e.g.
# https://design.example.com/latest. Leave UNSET to serve the committed copy as
# is — no private hostname in the repo, offline-safe, fork-friendly. After first
# boot the DB value wins, so flip it live from the settings cog (house-style URL)
# on an existing install rather than editing this file.
TANK_HOUSE_STYLE_URL=

# ── Runtime (GUI-editable; these only seed a fresh DB) ────────────────────────
# Parent dir for projects created from the dashboard.
TANK_PROJECTS_ROOT=/home/tank/projects
# Per-task git worktrees for isolate_tasks projects (kept outside project trees).
TANK_WORKTREES_ROOT=/home/tank/tank-worktrees
# Disposable cwds for chat-kind projects.
TANK_CHATS_ROOT=/tmp/tank-chat
# Max concurrent task spawns (semaphore size; restart to change).
TANK_MAX_CONCURRENT=3
# Inclusive port range tank draws from for per-task live dev previews (run a
# project's dev_command from a task's worktree on a dedicated port). Format
# "lo-hi"; the ports must be reachable on the host.
TANK_PREVIEW_PORT_RANGE=7900-7950

# AI title + todo tidy-up. Off by default. When on, tank calls an
# OpenAI-compatible chat-completions endpoint to name tasks/chats and clean up
# todos. When off, tasks keep their placeholder titles.
TANK_AI_FEATURES_ENABLED=0
TANK_TITLE_MODEL_URL=
TANK_TITLE_MODEL=

# Git provider for the per-task PR/merge buttons. "none" hides them.
# "forgejo" expects the project's origin remote to embed an API token
# (https://<user>:<token>@<host>/<owner>/<repo>.git).
TANK_GIT_PROVIDER=none

# Forgejo base URL + API token for the header "flatten repo" feature (list
# repos and download any repo flattened into a single text file). Independent
# of TANK_GIT_PROVIDER. Leave blank to disable; configure live via the cog.
TANK_FORGEJO_URL=
TANK_FORGEJO_TOKEN=

# Heading shown in the dashboard header + browser tab.
TANK_DASHBOARD_TITLE=tank

# Shared bearer token for the HTTP API. Blank = auth OFF (the LAN-trust
# default): anyone who can reach the server can drive it. When set, every
# request must carry the token — external callers send
# "Authorization: Bearer <token>"; the browser SPA unlocks via the { } API
# button (stored locally, sent as a same-origin cookie). A few paths stay open
# regardless: /health, /llms.txt, /docs, /openapi.json, and the local hook
# receiver. See GET /llms.txt for the agent-facing API guide.
TANK_API_TOKEN=
