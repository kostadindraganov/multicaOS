    }\n    _resolved = true;\n    return _currentUserId;\n  })", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/identity.ts", "source_location": "L67"}, {"caller_nid": "identity_authenticatedfetch", "callee": "has", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/identity.ts", "source_location": "L152"}, {"caller_nid": "identity_authenticatedfetch", "callee": "set", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/identity.ts", "source_location": "L154"}, {"caller_nid": "identity_authenticatedfetch", "callee": "hostFetch", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/identity.ts", "source_location": "L162"}, {"caller_nid": "identity_authenticatedfetch", "callee": "toString", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/identity.ts", "source_location": "L162"}, {"caller_nid": "identity_authenticatedfetch", "callee": "getOmnigentHostConfig", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/identity.ts", "source_location": "L172"}, {"caller_nid": "identity_authenticatedfetch", "callee": "includes", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/identity.ts", "source_location": "L174"}, {"caller_nid": "identity_authenticatedfetch", "callee": "toString", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/identity.ts", "source_location": "L174"}, {"caller_nid": "identity_authenticatedfetch", "callee": "includes", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/identity.ts", "source_location": "L175"}, {"caller_nid": "identity_authenticatedfetch", "callee": "toString", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/identity.ts", "source_location": "L175"}, {"caller_nid": "identity_authenticatedfetch", "callee": "getCachedServerInfo", "source_file": "/User