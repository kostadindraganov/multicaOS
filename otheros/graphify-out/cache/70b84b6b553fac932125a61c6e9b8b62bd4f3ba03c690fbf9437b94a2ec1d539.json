koko_desktop_multicaos_otheros_omnigent_web_src_lib_capabilities_ts", "target": "capabilities_sandboxoptionlabel", "relation": "contains", "confidence": "EXTRACTED", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/capabilities.ts", "source_location": "L162", "weight": 1.0}], "raw_calls": [{"caller_nid": "capabilities_resolveserverinfo", "callee": "(async () => {\n    try {\n      // Route through the host transport (`hostFetch`) so the embed hits the\n      // proxied omnigent API; standalone `hostFetch` falls back to plain\n      // `fetch(\"/v1/info\")`, preserving the original behavior.\n      const res = await hostFetch(\"/v1/info\");\n      if (res.ok) {\n        const data = (await res.json()) as Partial<ServerInfo>;\n        _cached = {\n          accounts_enabled: data.accounts_enabled === true,\n          login_url: typeof data.login_url === \"string\" ? data.login_url : null,\n          needs_setup: data.needs_setup === true,\n          databricks_features: data.databricks_features === true,\n          managed_sandboxes_enabled: data.managed_sandboxes_enabled === true,\n          sandbox_provider:\n            typeof data.sandbox_provider === \"string\" ? data.sandbox_provider : null,\n          server_version: typeof data.server_version === \"string\" ? data.server_version : null,\n          smart_routing_enabled: data.smart_routing_enabled === true,\n        };\n        return _cached;\n      }\n    } catch {\n      // Network failure \u2014 fall through to the off sentinel.\n    }\n    _cached = _OFF;\n    return _cached;\n  })", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/capabilities.ts", "source_location": "L99"}, {"caller_nid": "capabilities_sandboxoptionlabel", "callee": "toUpperCase", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/capabilities.ts", "source_location": "L165"}, {"caller_nid": "capabilities_sandboxoptionlabel", "callee": "charAt", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/capabilities.ts", "source_location": "L165"}, {"caller_nid": "capabilities_sandboxoptionlabel", "callee": "slice", "source_file": "/Users/cyberkoko/Desktop/multicaOS/otheros/omnigent/web/src/lib/capabilities.ts", "source_location": "L165"}]}